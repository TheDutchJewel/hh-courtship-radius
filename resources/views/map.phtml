<?php

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Fisharebest\Webtrees\View;

/** @var array<string,mixed> $data */
/** @var object $leaflet_config */

$mapId = 'courtship-radius-map-' . bin2hex(random_bytes(4));
$controlId = $mapId . '-radius-controls';
?>
<div id="<?= e($controlId) ?>" class="btn-group btn-group-sm mb-2" role="group" aria-label="<?= e(I18N::translate('Reference circle')) ?>">
    <button class="btn btn-outline-primary" type="button" data-sex="M" <?= $data['reference_circles']['M'] === null ? 'disabled' : '' ?>><?= I18N::translate('Men’s P90 circle') ?></button>
    <button class="btn btn-outline-danger" type="button" data-sex="F" <?= $data['reference_circles']['F'] === null ? 'disabled' : '' ?>><?= I18N::translate('Women’s P90 circle') ?></button>
    <button class="btn btn-outline-secondary" type="button" data-sex=""><?= I18N::translate('Remove circle') ?></button>
</div>
<div id="<?= e($mapId) ?>" class="wt-map border rounded" dir="ltr" style="height:36rem"></div>
<p class="small text-muted mt-2"><?= I18N::translate('Blue routes represent men; pink routes represent women. The line width and number show the number of persons. Each P90 circle is centred on the most frequent birth place for that group; its radius is the mean of the available time-slice P90 values.') ?></p>

<?php View::push('javascript') ?>
<script>
(() => {
  'use strict';
  const config = <?= json_encode($leaflet_config, JSON_THROW_ON_ERROR) ?>;
  const data = <?= json_encode($data, JSON_THROW_ON_ERROR | JSON_UNESCAPED_UNICODE) ?>;
  const controls = document.getElementById(<?= json_encode($controlId, JSON_THROW_ON_ERROR) ?>);
  const map = webtrees.buildLeafletJsMap(<?= json_encode($mapId, JSON_THROW_ON_ERROR) ?>, config, event => {
    event.preventDefault();
    if (layers.getLayers().length) map.fitBounds(layers.getBounds(), {padding: [30, 30], maxZoom: 14});
  });
  const layers = L.featureGroup().addTo(map);
  const color = sex => sex === 'M' ? '#2563eb' : '#db2777';
  const escapeHtml = value => String(value).replace(/[&<>'"]/g, character => ({'&':'&amp;','<':'&lt;','>':'&gt;',"'":'&#39;','"':'&quot;'}[character]));
  let radiusCircle = null;

  controls.addEventListener('click', event => {
    const button = event.target.closest('[data-sex]');
    if (!button) return;
    const sex = button.dataset.sex;
    controls.querySelectorAll('[data-sex]').forEach(item => item.classList.remove('active'));
    button.classList.add('active');
    if (radiusCircle !== null) {
      radiusCircle.remove();
      radiusCircle = null;
    }

    if (sex === '') {
      if (layers.getLayers().length) map.fitBounds(layers.getBounds(), {padding: [30, 30], maxZoom: 14});
      return;
    }

    const reference = data.reference_circles[sex];
    if (reference === null) return;
    const centre = [reference.center.latitude, reference.center.longitude];
    const radiusLabel = reference.radius.toLocaleString(document.documentElement.lang || undefined, {maximumFractionDigits: 1});
    radiusCircle = L.circle(centre, {radius: reference.radius * 1000, color: color(sex), fillOpacity: .08})
      .bindTooltip(`${escapeHtml(reference.center.name)} (n=${reference.person_count}): P90 ${radiusLabel} km`)
      .addTo(map);
    map.fitBounds(radiusCircle.getBounds(), {padding: [30, 30]});
  });

  data.routes.forEach(route => {
    const start = [route.origin.latitude, route.origin.longitude];
    const end = [route.destination.latitude, route.destination.longitude];
    const routeColor = color(route.sex);
    const width = 2 + Math.log2(route.count + 1);
    const label = `${escapeHtml(route.origin.name)} → ${escapeHtml(route.destination.name)}: ${route.count}`;
    L.polyline([start, end], {color: routeColor, weight: width, opacity: .75}).bindTooltip(label).addTo(layers);
    L.circleMarker(start, {radius: 3 + Math.sqrt(route.count), color: routeColor, fillOpacity: .65}).bindTooltip(escapeHtml(route.origin.name)).addTo(layers);
    const middle = [(start[0] + end[0]) / 2, (start[1] + end[1]) / 2];
    const countIcon = L.divIcon({className: '', iconSize: [28, 20], iconAnchor: [14, 10], html: `<span style="display:block;text-align:center;color:#fff;background:${routeColor};border-radius:10px;font-size:11px;line-height:18px">${route.count}</span>`});
    L.marker(middle, {icon: countIcon, interactive: false}).addTo(layers);
    const angle = Math.atan2(end[0] - start[0], end[1] - start[1]) * 180 / Math.PI;
    const icon = L.divIcon({className: '', iconSize: [20, 20], iconAnchor: [10, 10], html: `<span aria-hidden="true" style="display:block;color:${routeColor};font-size:20px;line-height:20px;transform:rotate(${-angle}deg)">➤</span>`});
    L.marker(end, {icon}).bindTooltip(label).addTo(layers);
  });

  data.same_place.forEach(place => {
    L.circleMarker([place.latitude, place.longitude], {radius: 5 + Math.sqrt(place.count) * 2, color: color(place.sex), weight: 3, fillOpacity: .3})
      .bindTooltip(`${escapeHtml(place.name)}: ${place.count}`).addTo(layers);
  });

  if (layers.getLayers().length) {
    map.fitBounds(layers.getBounds(), {padding: [30, 30], maxZoom: 14});
  } else {
    map.fitWorld();
  }
})();
</script>
<?php View::endpush() ?>
